# Reference checkout of graphify used for local dev/testing — not this repo's code.
/graphify/

# Unrelated nested git repo (own remote) that happens to sit in this working dir.
/ObsidianVault/

# Repo graph: graph.json + code-manifest.jsonl are the committed, portable source
# (deterministic, relative paths). Everything else here is a machine-local
# cache or a derived report/viz — regenerated by `graphify update .`.
graphify-out/cache/
graphify-out/manifest.json
graphify-out/.graphify_analysis.json
graphify-out/.graphify_labels.json
graphify-out/.graphify_root
graphify-out/graph.html
graphify-out/GRAPH_REPORT.md
